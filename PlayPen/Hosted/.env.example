HOST=127.0.0.1
PORT=4177
PLAYPEN_STORAGE_DRIVER=filesystem
PLAYPEN_STORE_DIR=.playpen-store
PLAYPEN_PUBLIC_BASE_URL=http://127.0.0.1:4177
PLAYPEN_PUBLISH_TOKEN=

# S3-compatible storage for public deployments without durable local disk:
# PLAYPEN_STORAGE_DRIVER=s3
# PLAYPEN_S3_BUCKET=playpen
# PLAYPEN_S3_REGION=auto
# PLAYPEN_S3_ENDPOINT=https://accountid.r2.cloudflarestorage.com
# PLAYPEN_S3_PREFIX=playgrounds
# PLAYPEN_S3_FORCE_PATH_STYLE=true
# PLAYPEN_S3_ACCESS_KEY_ID=
# PLAYPEN_S3_SECRET_ACCESS_KEY=

# Do not commit real publish tokens, object-storage credentials, deployment
# credentials, private keys, or Apple signing secrets.
